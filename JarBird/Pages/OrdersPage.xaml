<Page x:Class="JarBird.Pages.OrdersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JarBird.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrdersPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Заказы" FontSize="30" HorizontalAlignment="Center"/>
        <ListBox x:Name="OrdersListBox" 
                 HorizontalContentAlignment="Stretch"
                 Grid.Row="1" 
                 SelectionChanged="OrdersListBox_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Vertical">
                            <TextBlock Text="{Binding IDOrders}"/>
                            <TextBlock Text="{Binding Statuses.StatusName}"/>
                            <TextBlock Text="{Binding DeliveryAddress}"/>
                            <TextBlock Text="{Binding OrderDate}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DeliveryDate}" Grid.Column="1"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button x:Name="AddOrderButton" Content="Добавить заказ" Grid.Row="2" Click="AddOrderButton_Click"/>
    </Grid>
</Page>
