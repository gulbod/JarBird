<Page x:Class="JarBird.Pages.KorzinaPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JarBird.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="KorzinaPage" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Корзина" FontSize="30" HorizontalAlignment="Center" VerticalAlignment="Top" Grid.Row="0"/>
        <TextBlock x:Name="FIOTextBlock" HorizontalAlignment="Right" Grid.Row="0"/>
        <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom">
            <TextBlock Text="DeliveryAddress"/>
            <TextBox x:Name="DeliveryAddressTextBox" Width="100"/>
        </StackPanel>
        <ListBox Grid.Row="1" x:Name="KorzinaListBox" SelectionChanged="KorzinaListBox_SelectionChanged">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="3"/>
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="#e0e0e0" BorderThickness="1" CornerRadius="5" Margin="5" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="IDProduct" Text="{Binding Products.ProductName}" Grid.Column="0"/>
                            <StackPanel Orientation="Horizontal" Grid.Column="1">
                                <TextBlock x:Name="Quantity" Text="{Binding Quantity}"/>
                                <TextBlock x:Name="PriceInOrder" Text="{Binding PriceInOrder, StringFormat={}{0}  ₽}"/>
                            </StackPanel>
                            <TextBlock x:Name="LineTotal" Text="{Binding LineTotal, StringFormat={}{0}  ₽}" Grid.Column="2"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>

        </ListBox>
        <Button x:Name="AllKorzinaButton" Content="Заказать всю корзину" Grid.Row="2" Click="AllKorzinaButton_Click"/>
        <Button x:Name="BackButton" Content="Назад" Grid.Row="2" HorizontalAlignment="Left" Click="BackButton_Click"/>
    </Grid>
</Page>
