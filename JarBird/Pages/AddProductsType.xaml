<Page x:Class="JarBird.Pages.AddProductsType"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JarBird.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddProductsType">

    <Grid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
            <StackPanel Orientation="Vertical" HorizontalAlignment="Right">
                <TextBlock x:Name="IDProductTextBlock2" Text="IDProduct" />
                <TextBlock Text="ProductName"/>
                <TextBlock Text="IDProductType"/>
                <TextBlock Text="Description"/>
                <TextBlock Text="Composition"/>
                <TextBlock Text="Price"/>
                <TextBlock Text="DiscountProcent"/>
                <TextBlock Text="IsDiscountActive"/>
                <TextBlock Text="MinStock"/>
                <TextBlock Text="QuantityInStock"/>
                <TextBlock Text="Image"/>
                <Button x:Name="DelButton" Content="Удалить" VerticalAlignment="Bottom" Margin="0,55,0,0" Click="DelButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock x:Name="IDProductTextBlock" Text="{Binding IDProduct}"/>
                <TextBox x:Name="ProductNameTextBox" Text="{Binding ProductName}"/>
                <ComboBox x:Name="IDProductTypeComboBox" DisplayMemberPath="ProductTypeName" Text="{Binding ProductTypes.ProductTypeName}"/>
                <TextBox x:Name="DescriptionTextBox" Text="{Binding Description}"/>
                <TextBox x:Name="CompositionTextBox" Text="{Binding Composition}"/>
                <TextBox x:Name="PriceTextBox" Text="{Binding Price}"/>
                <TextBox x:Name="DiscountProcentTextBox" Text="{Binding DiscountProcent}"/>
                <TextBox x:Name="IsDiscountActiveTextBox" Text="{Binding IsDiscountActive}"/>
                <TextBox x:Name="MinStockTextBox" Text="{Binding MinStock}"/>
                <TextBox x:Name="QuantityInStockTextBox" Text="{Binding QuantityInStock}"/>
                <Image Width="40" Height="50" x:Name="ImageAploud">
                    <Image.Source>
                        <Binding Path="ImagePath">
                            <Binding.TargetNullValue>
                                <ImageSource>../images/picture.png</ImageSource>
                            </Binding.TargetNullValue>
                        </Binding>
                    </Image.Source>
                </Image>
                <Button x:Name="SaveButton" Content="Сохранить" Click="SaveButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
