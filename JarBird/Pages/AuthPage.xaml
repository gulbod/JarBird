<Page x:Class="JarBird.Pages.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:JarBird.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AuthPage">

    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center" Height="200" Width="200">
            <TextBlock x:Name="Login" Text="Логин"/>
            <TextBox x:Name="LoginTextBox"/>
            <TextBlock x:Name="Password" Text="Пароль"/>
            <PasswordBox x:Name="PassPasswordBox"/>
            <Button x:Name="AuthButton" Content="Авторизоваться" Click="AuthButton_Click"/>
            <Button x:Name="GuestButton" Content="Войти как Гость" Click="GuestButton_Click"/>

        </StackPanel>
        
    </Grid>
</Page>
